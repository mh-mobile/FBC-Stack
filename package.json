{
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "predev": "rm -rf public/posts && mkdir -p public/posts && cp -R posts/*.md public/posts",
    "prebuild": "rm -rf public/posts && mkdir -p public/posts && cp -R posts/*.md public/posts",
    "build": "next build",
    "dev": "npm run predev && next dev --experimental-https",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json}'",
    "cypress": "cypress open",
    "cypress:headless": "cypress run",
    "e2e": "start-server-and-test start http://localhost:3000 cypress",
    "e2e:headless": "start-server-and-test start http://localhost:3000 cypress:headless"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "date-fns": "^2.29.3",
    "gray-matter": "^4.0.3",
    "next": "^15.5.20",
    "postcss": "^8.5.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/gtag.js": "^0.0.12",
    "@types/node": "^18.11.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cypress": "^15.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.20",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "prettier": "^2.8.1",
    "start-server-and-test": "^2.0.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
